# MCP Server (downstream CeramiCraft MCP Server)
CS_AGENT_MCP_SERVER_URL=http://mcp-server-svc:8080/mcp

# LLM (OpenAI)
CS_AGENT_OPENAI_API_KEY=
CS_AGENT_OPENAI_MODEL=gpt-4o

# HTTP Server Configuration
CS_AGENT_HTTP_HOST=0.0.0.0
CS_AGENT_HTTP_PORT=8080

# gRPC Server Configuration
CS_AGENT_GRPC_HOST=[::]
CS_AGENT_GRPC_PORT=50051

# LangSmith (optional — CS_AGENT_LANGSMITH_API_KEY is forwarded to
# LANGCHAIN_API_KEY at startup so LangChain picks it up automatically)
CS_AGENT_LANGSMITH_API_KEY=
CS_AGENT_LANGSMITH_PROJECT=ceramicraft-cs-agent

# MLflow (optional — leave blank to disable tracing)
MLFLOW_TRACKING_URI=
CS_AGENT_MLFLOW_EXPERIMENT_NAME=ceramicraft-cs-agent

# ─── PostgreSQL (conversation checkpoint) ────────────────────────────────────
# Uses the same shared postgres container as log-ms and notification-ms.
# Database cs_agent_db is created automatically by local-stack postgres init scripts.
# POSTGRES_HOST is required — the agent will fail to start if not configured.
POSTGRES_USER=ceramicraft
POSTGRES_PASSWORD=ceramicraft123
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
CS_AGENT_DB_NAME=cs_agent_db

# Max messages passed to subgraphs (trim older history to prevent token explosion)
CS_AGENT_MAX_HISTORY=20
