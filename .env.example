# ─── MCP Server (downstream CeramiCraft MCP Server) ──────────────────────
# Local dev: use localhost with mapped port from docker-compose.
# In cluster: set via values.yaml extraEnv (http://mcp-server-svc.default.svc.cluster.local:8080/mcp).
CS_AGENT_MCP_SERVER_URL=http://localhost:8088/mcp

# ─── LLM (OpenAI) ────────────────────────────────────────────────────────
CS_AGENT_OPENAI_API_KEY=
CS_AGENT_OPENAI_MODEL=gpt-4o

# ─── HTTP Server ──────────────────────────────────────────────────────────
CS_AGENT_HTTP_HOST=0.0.0.0
CS_AGENT_HTTP_PORT=8080

# ─── gRPC Server ──────────────────────────────────────────────────────────
CS_AGENT_GRPC_HOST=[::]
CS_AGENT_GRPC_PORT=50051

# ─── LangSmith (optional) ────────────────────────────────────────────────
# CS_AGENT_LANGSMITH_API_KEY is forwarded to LANGCHAIN_API_KEY at startup
# so LangChain picks it up automatically.
CS_AGENT_LANGSMITH_API_KEY=
CS_AGENT_LANGSMITH_PROJECT=customer-support-agent

# ─── MLflow (optional — leave blank to disable tracing) ──────────────────
# In cluster: set via values.yaml extraEnv (http://mlflow.mlflow.svc.cluster.local).
MLFLOW_TRACKING_URI=
CS_AGENT_MLFLOW_EXPERIMENT_NAME=customer-support-agent

# ─── PostgreSQL (conversation checkpoint) ─────────────────────────────────
# Shared with other services; in cluster injected via Vault.
POSTGRES_USER=ceramicraft
POSTGRES_PASSWORD=ceramicraft123
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
CS_AGENT_DB_NAME=cs_agent_db

# ─── Agent Behavior ──────────────────────────────────────────────────────
CS_AGENT_MAX_HISTORY=20
