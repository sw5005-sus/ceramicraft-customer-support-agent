# MCP Server (downstream CeramiCraft MCP Server)
MCP_SERVER_URL=http://mcp-server-svc:8080/mcp

# LLM (OpenAI)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Agent Server
AGENT_HOST=0.0.0.0
AGENT_PORT=8080

# LangSmith (optional)
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=ceramicraft-cs-agent

# MLflow (optional — leave blank to disable tracing)
MLFLOW_TRACKING_URI=
MLFLOW_EXPERIMENT_NAME=ceramicraft-cs-agent

# ─── PostgreSQL (conversation checkpoint) ────────────────────────────────────
# Uses the same shared postgres container as log-ms and notification-ms.
# Set POSTGRES_USER / PASSWORD / HOST / PORT — consistent with cluster convention.
# Database cs_agent_db is created automatically by local-stack postgres init scripts.
# Leave all blank to fall back to in-memory storage (history lost on restart).
POSTGRES_USER=ceramicraft
POSTGRES_PASSWORD=ceramicraft123
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
CS_AGENT_DB_NAME=cs_agent_db

# Optional: explicit URL override (takes priority over individual vars above).
# Format: postgresql+psycopg://user:password@host:port/dbname
POSTGRES_URL=

# Max messages passed to subgraphs (trim older history to prevent token explosion)
AGENT_MAX_HISTORY=20
