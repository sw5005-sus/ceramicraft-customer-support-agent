# MCP Server (downstream CeramiCraft MCP Server)
MCP_SERVER_URL=http://mcp-server-svc:8080/mcp

# LLM (OpenAI)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Agent Server
AGENT_HOST=0.0.0.0
AGENT_PORT=8080

# LangSmith (optional)
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=ceramicraft-cs-agent

# MLflow (optional — leave blank to disable tracing)
MLFLOW_TRACKING_URI=
MLFLOW_EXPERIMENT_NAME=ceramicraft-cs-agent

# PostgreSQL checkpoint for conversation history persistence
# Format: postgresql+psycopg://user:password@host:port/dbname
# Leave empty to use in-memory storage (lost on restart)
POSTGRES_URL=postgresql+psycopg://ceramicraft:ceramicraft123@postgres:5432/cs_agent_db
AGENT_MAX_HISTORY=20
